{
  "name": "english",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "node ./node_modules/vite/bin/vite.js",
    "dev:server": "PORT=8770 node --watch server/index.js",
    "serve": "HOST=0.0.0.0 PORT=8770 NODE_ENV=production node server/index.js",
    "build": "node ./node_modules/typescript/lib/_tsc.js -b && node ./node_modules/vite/bin/vite.js build",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "express": "^5.2.1",
    "undici": "^5.29.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
